# Required for Turbopack (Next.js) to resolve packages from root node_modules.
# Turbopack uses the monorepo root as the workspace root for module resolution.
# Without hoisting, workspace packages (e.g., wagmi) are only accessible via
# pnpm's virtual store symlinks in each workspace's node_modules, which
# Turbopack cannot traverse across symlink boundaries.
public-hoist-pattern[]=*
shamefully-hoist=true
