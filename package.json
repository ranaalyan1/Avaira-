{
  "name": "avaira-protocol",
  "version": "1.0.0",
  "private": true,
  "description": "Avaira Protocol — Autonomous AI Agents on Avalanche",
  "scripts": {
    "dev": "pnpm --filter frontend dev",
    "dev:backend": "cd backend && npm run dev",
    "compile": "cd contracts && npx hardhat compile",
    "test": "cd contracts && npx hardhat test",
    "deploy:fuji": "cd contracts && npx hardhat run scripts/deploy.cjs --network fuji",
    "build": "pnpm --filter frontend build"
  },
  "workspaces": [
    "contracts",
    "frontend",
    "sdk"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "web3",
    "avalanche",
    "ai-agents",
    "autonomous",
    "defi",
    "hardhat",
    "nextjs"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs"
}
